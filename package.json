{
  "name": "tsargrad-demographic-platform-release-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Автоматизированные проверки для самодостаточной GitHub Pages-платформы Россия 2050",
  "scripts": {
    "check": "python scripts/audit_all.py",
    "check:json": "python scripts/check_json.py",
    "check:settlement": "python scripts/check_settlement_forecast.py",
    "check:external": "python scripts/check_no_external_runtime.py",
    "check:russian": "python scripts/check_russian_ui.py",
    "check:data": "python scripts/check_data_locality.py",
    "check:nav": "python scripts/check_nav_numbering.py",
    "check:js": "bash scripts/check_js_syntax.sh",
    "test:smoke": "playwright test tests/smoke.spec.js tests/visual-qa.spec.js",
    "test:responsive": "playwright test tests/responsive.spec.js && python scripts/make_responsive_contact_sheets.py",
    "serve": "python -m http.server 8000 --directory docs"
  },
  "devDependencies": {
    "@playwright/test": "latest"
  }
}
